---
---
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Comando - Login</title>

    <script src="https://accounts.google.com/gsi/client" async defer></script>

    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(180deg, #0b0b0f 0%, #14141c 100%);
        font-family: Arial, sans-serif;
        color: white;
      }

      .container {
        width: 100%;
        max-width: 420px;
        padding: 32px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.06);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.45);
        text-align: center;
      }

      h1 {
        margin: 0 0 10px;
        font-size: 36px;
      }

      p {
        margin: 0 0 24px;
        color: #c7c7d1;
      }

      .status {
        margin-top: 20px;
        min-height: 24px;
        font-size: 14px;
      }

      .error {
        color: #ff7b7b;
      }

      .success {
        color: #7dffb0;
      }

      .loader {
        display: none;
        margin-top: 16px;
        color: #9ad8ff;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h1>Comando</h1>
      <p>Entrar com Google</p>

      <div id="googleButton"></div>

      <div id="loader" class="loader">Entrando...</div>
      <div id="status" class="status"></div>
    </div>

    <script>
      const GOOGLE_CLIENT_ID = '948102948683-u0o9lg73rprka2t0pp0tr4ol96echnf4.apps.googleusercontent.com';
      const BACKEND_URL = 'https://comando-server.onrender.com/auth/google';

      const statusEl = document.getElementById('status');
      const loaderEl = document.getElementById('loader');

      function setStatus(message, type = '') {
        statusEl.textContent = message;
        statusEl.className = `status ${type}`;
      }

      function setLoading(isLoading) {
        loaderEl.style.display = isLoading ? 'block' : 'none';
      }

      async function handleCredentialResponse(response) {
        try {
          setLoading(true);
          setStatus('');

          const googleToken = response.credential;

          const apiResponse = await fetch(BACKEND_URL, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              token: googleToken,
            }),
          });

          const data = await apiResponse.json();

          if (!apiResponse.ok || !data.success) {
            throw new Error(data.error || data.details || 'Falha no login');
          }

          localStorage.setItem('authToken', data.token);
          localStorage.setItem('playerData', JSON.stringify(data.player));

          setStatus('Login realizado com sucesso!', 'success');

          setTimeout(() => {
            window.location.href = '/game';
          }, 1000);
        } catch (error) {
          console.error(error);
          setStatus('Erro ao entrar com Google.', 'error');
        } finally {
          setLoading(false);
        }
      }

      window.onload = function () {
        google.accounts.id.initialize({
          client_id: GOOGLE_CLIENT_ID,
          callback: handleCredentialResponse,
        });

        google.accounts.id.renderButton(
          document.getElementById('googleButton'),
          {
            theme: 'outline',
            size: 'large',
            shape: 'pill',
            text: 'signin_with',
            width: 280,
          }
        );
      };
    </script>
  </body>
</html>